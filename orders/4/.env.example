# Server — dev preview often uses 3106 (do not use forbidden ports listed in README)
PORT=3106
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_4` only
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_4

# Legacy aliases (optional)
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

SESSION_SECRET=change-me-to-a-long-random-string

GA_MEASUREMENT_ID=

WHATSAPP_NUMBER=

CONTACT_WEBHOOK_URL=

# Optional: POST JSON on successful checkout
ORDER_WEBHOOK_URL=

SITE_URL=http://localhost:3106

# PM2 — autonix-order-4-dev (dev) or autonix-order-4-main (production)
# PM2_APP_NAME=autonix-order-4-dev
