<div class="container page-narrow">
  <h1 class="page-title">Your cart</h1>
  <% if (!lines.length) { %>
  <p class="muted">Your cart is empty. <a href="/#shop">Browse groceries</a>.</p>
  <% } else { %>
  <form method="post" action="/cart/update">
    <ul class="cart-list">
      <% lines.forEach(function (line) { %>
      <li class="cart-line">
        <a class="cart-thumb" href="/p/<%= line.product.slug %>"><img src="<%= productImageUrl(line.product) %>" alt="" width="120" height="90" loading="lazy" decoding="async" /></a>
        <div class="cart-line-main">
          <a href="/p/<%= line.product.slug %>"><strong><%= line.product.name %></strong></a>
          <p class="muted">$<%= formatMoney(line.product.priceCents) %> each</p>
        </div>
        <label class="field qty-field">
          <span class="sr-only">Quantity for <%= line.product.name %></span>
          <input type="number" name="qty_<%= line.product.id %>" min="0" max="99" value="<%= line.quantity %>" />
        </label>
        <div class="cart-line-total">$<%= formatMoney(line.lineTotalCents) %></div>
        <button type="submit" class="btn btn-text" formaction="/cart/remove" formmethod="post" name="product_id" value="<%= line.product.id %>">Remove</button>
      </li>
      <% }); %>
    </ul>
    <div class="cart-actions">
      <button type="submit" class="btn btn-ghost">Update cart</button>
    </div>
  </form>
  <div class="cart-summary">
    <p><strong>Subtotal</strong> <span>$<%= formatMoney(subtotalCents) %></span></p>
    <p class="muted small">Delivery fees and tax may apply — confirmed in your order email.</p>
    <a class="btn btn-primary" href="/checkout">Checkout</a>
  </div>
  <% } %>
</div>
