<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-media" aria-hidden="true">
    <img src="<%= clientHeroUrl %>" alt="" width="1920" height="1080" fetchpriority="high" />
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container hero-inner">
    <p class="hero-eyebrow">Food · Forest kitchen</p>
    <h1 id="hero-heading">Welcome to Hippo</h1>
    <p>Seasonal plates, a calm dining room, and an online shop so you can reorder your favorites anytime — from grain bowls to burgers and late-night desserts.</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/shop">Order online</a>
      <a class="btn btn-ghost" href="/menu">View menu</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>Restaurant food, e-commerce flow</h2>
      <p>Hippo is built for guests who want full-flavor cooking without the fuss: browse by category, build a cart, and check out with clear delivery details.</p>
    </div>
    <div class="split">
      <div class="split-media">
        <img src="<%= clientHeroUrl %>" alt="Hippo hero — food and atmosphere" width="800" height="600" loading="lazy" />
      </div>
      <div class="prose">
        <h2>What we cook</h2>
        <p>We lean into vegetables, herbs, and responsibly sourced proteins — plated with a forest-inspired palette of deep greens, warm wood, and golden accents.</p>
        <ul class="feature-list">
          <li>Mains made for sharing or solo nights in</li>
          <li>Sides and salads that stand on their own</li>
          <li>House desserts and cold drinks to round out your order</li>
        </ul>
        <div class="stack-actions" style="margin-top: 1.75rem;">
          <a class="btn btn-secondary" href="/about">Our story</a>
          <a class="btn btn-primary" href="/contact">Book or ask a question</a>
        </div>
      </div>
    </div>
  </div>
</section>
