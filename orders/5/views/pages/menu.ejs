<div class="container page-hero">
  <h1>Menu</h1>
  <p>Everything on our menu is also available in the shop — add to cart for pickup or delivery where we operate.</p>
</div>

<section class="section section-tight">
  <div class="container">
    <% 
      const categoryLabel = (c) => {
        if (c === 'mains') return 'Mains';
        if (c === 'sides') return 'Sides & salads';
        if (c === 'dessert') return 'Dessert';
        if (c === 'drinks') return 'Drinks';
        return c.charAt(0).toUpperCase() + c.slice(1);
      };
      const byCat = {};
      (products || []).forEach((p) => {
        const k = p.category || 'mains';
        if (!byCat[k]) byCat[k] = [];
        byCat[k].push(p);
      });
      const order = ['mains', 'sides', 'dessert', 'drinks'];
      const keys = order.filter((k) => byCat[k]).concat(Object.keys(byCat).filter((k) => !order.includes(k)).sort());
    %>
    <% keys.forEach((cat) => { %>
      <div class="section-head" style="margin-top: 2rem;">
        <h2><%= categoryLabel(cat) %></h2>
      </div>
      <div class="card-grid">
        <% byCat[cat].forEach((product) => { %>
        <article class="card">
          <a href="/shop/<%= product.slug %>" class="card-media">
            <img src="<%= productImageUrl(product) %>" alt="" width="600" height="450" loading="lazy" />
          </a>
          <div class="card-body">
            <span class="pill"><%= categoryLabel(product.category) %></span>
            <h3><a href="/shop/<%= product.slug %>" style="text-decoration:none;color:inherit;"><%= product.name %></a></h3>
            <p style="margin:0;color:var(--text-muted);font-size:0.95rem;"><%= product.description %></p>
            <div class="card-meta">
              <span class="price">$<%= formatMoney(product.priceCents) %></span>
              <a class="btn btn-secondary" style="padding:0.5rem 1rem;font-size:0.85rem;" href="/shop/<%= product.slug %>">Details</a>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
    <% }); %>
  </div>
</section>
