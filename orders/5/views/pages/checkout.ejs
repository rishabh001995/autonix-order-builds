<div class="container page-hero">
  <h1>Checkout</h1>
  <p>Enter delivery details for your Hippo order. This site records your order in our database — there is no live card payment on this demo.</p>
</div>

<section class="section section-tight">
  <div class="container split">
    <div>
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error" role="alert">Please complete email, full name, street address, city, and postal code.</div>
      <% } %>
      <form method="post" action="/checkout" class="forms" style="max-width:none;">
        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="form-row">
          <label for="full_name">Full name</label>
          <input id="full_name" name="full_name" type="text" required autocomplete="name" />
        </div>
        <div class="form-row">
          <label for="phone">Phone <span class="form-hint" style="display:inline;font-weight:400;">(optional)</span></label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" />
        </div>
        <div class="form-row">
          <label for="address_line1">Street address</label>
          <input id="address_line1" name="address_line1" type="text" required autocomplete="address-line1" />
        </div>
        <div class="form-row">
          <label for="address_line2">Apt, suite <span class="form-hint" style="display:inline;font-weight:400;">(optional)</span></label>
          <input id="address_line2" name="address_line2" type="text" autocomplete="address-line2" />
        </div>
        <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div>
            <label for="city">City</label>
            <input id="city" name="city" type="text" required autocomplete="address-level2" />
          </div>
          <div>
            <label for="region">State / region <span class="form-hint" style="display:inline;font-weight:400;">(optional)</span></label>
            <input id="region" name="region" type="text" autocomplete="address-level1" />
          </div>
        </div>
        <div class="form-row">
          <label for="postal">Postal code</label>
          <input id="postal" name="postal" type="text" required autocomplete="postal-code" />
        </div>
        <div class="form-row">
          <label for="notes">Order notes <span class="form-hint" style="display:inline;font-weight:400;">(optional)</span></label>
          <textarea id="notes" name="notes" rows="3" placeholder="Allergies, pickup window, gate code…"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Place order</button>
      </form>
      <p class="form-hint" style="margin-top:1.25rem;"><a href="/cart">&larr; Back to cart</a></p>
    </div>
    <div class="card" style="padding:1.5rem;">
      <h2 style="font-family:var(--font-display);margin:0 0 1rem;color:var(--forest-900);">Order summary</h2>
      <ul style="list-style:none;padding:0;margin:0;">
        <% lines.forEach((line) => { %>
        <li style="padding:0.65rem 0;border-bottom:1px solid rgba(35,73,45,0.1);display:flex;gap:0.75rem;align-items:flex-start;">
          <img src="<%= productImageUrl(line.product) %>" alt="" width="48" height="48" style="border-radius:8px;object-fit:cover;flex-shrink:0;" loading="lazy" />
          <span><%= line.quantity %> × <%= line.product.name %> — <strong>$<%= formatMoney(line.lineTotalCents) %></strong></span>
        </li>
        <% }); %>
      </ul>
      <p class="price" style="font-size:1.25rem;margin-top:1.25rem;">Total: $<%= formatMoney(subtotalCents) %></p>
      <p class="form-hint">Tax, fees, and fulfillment timing may be confirmed by email.</p>
    </div>
  </div>
</section>
