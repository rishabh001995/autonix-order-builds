# Server — preview / dev often uses 3100 (do not use forbidden ports listed in README)
PORT=3100
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_1` only (matches Autonix ORDER_MYSQL_ADMIN_* on server unless overridden)
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_1

# Legacy aliases (optional) — if unset, ORDER_DB_* above is used
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: set true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

# Sessions — not used by this landing site; reserved for future use
SESSION_SECRET=change-me-to-a-long-random-string

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# WhatsApp Business — full international number, digits only (e.g. 15551234567)
WHATSAPP_NUMBER=

# Optional: Zapier / Make — webhook URL to receive contact form JSON POSTs
CONTACT_WEBHOOK_URL=

# Optional: public site URL for canonical / OG tags (no trailing slash)
SITE_URL=http://localhost:3100

# PM2 — set per deploy: autonix-order-1-dev (dev) or autonix-order-1-main (production)
# PM2_APP_NAME=autonix-order-1-dev
