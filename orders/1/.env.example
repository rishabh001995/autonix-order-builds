# Server
PORT=3100
NODE_ENV=development

# MySQL — use schema `autonix_order_1` only
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=autonix_order_1

# Sessions (generate a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: sync Sequelize models (creates/updates tables). Use false in production after migrations.
SYNC_DB=false

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# WhatsApp Business — full international number, digits only (e.g. 15551234567)
WHATSAPP_NUMBER=

# Optional: Zapier / Make — webhook URL to receive contact form JSON POSTs
CONTACT_WEBHOOK_URL=

# Optional: public site URL for canonical / OG tags (no trailing slash)
SITE_URL=http://localhost:3100
