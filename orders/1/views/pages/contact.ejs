<section class="page-hero">
  <div class="container narrow">
    <p class="eyebrow">Contact</p>
    <h1 class="display display--sm">Start a conversation</h1>
    <p class="lead">Tell us about your goals in 12. We reply to serious inquiries promptly.</p>
  </div>
</section>

<section class="section">
  <div class="container split">
    <div>
      <% if (typeof sent !== 'undefined' && sent) { %>
        <div class="notice notice--success" role="status">Thank you — your message was sent.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="notice notice--error" role="alert">Please complete all fields.</div>
      <% } %>
      <form class="stack-form" method="post" action="/contact" novalidate>
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn">Send message</button>
      </form>
      <p class="muted small">
        Optional: connect <strong>Zapier / Make</strong> by setting <code>CONTACT_WEBHOOK_URL</code> — form submissions POST as JSON to your automation.
      </p>
    </div>
    <div class="card">
      <h2 class="h3">WhatsApp</h2>
      <% if (whatsappNumber) { %>
        <p><a class="btn btn--ghost" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">Message on WhatsApp</a></p>
      <% } else { %>
        <p class="muted">WhatsApp can be enabled by setting <code>WHATSAPP_NUMBER</code> in your environment (digits only, international format).</p>
      <% } %>
      <h2 class="h3 mt-lg">Office region</h2>
      <p class="muted">Primary region: <strong>12</strong>. We coordinate site visits and shipping details as your transaction requires.</p>
    </div>
  </div>
</section>
