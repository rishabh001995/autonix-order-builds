<section class="page-hero">
  <div class="container narrow">
    <p class="eyebrow">Insights</p>
    <h1 class="display display--sm"><%= post.title %></h1>
    <% if (post.excerpt) { %><p class="lead"><%= post.excerpt %></p><% } %>
  </div>
</section>

<section class="section">
  <div class="container narrow prose">
    <%- post.body %>
    <p><a href="/blog" class="link-arrow">← Back to insights</a></p>
  </div>
</section>
