<section class="page-hero">
  <div class="container narrow">
    <p class="eyebrow">Insights</p>
    <h1 class="display display--sm">Market notes &amp; guides</h1>
    <p class="lead">Search articles from 12. Filters apply to title, excerpt, and body text.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <form class="search-bar" method="get" action="/blog" role="search">
      <label class="sr-only" for="q">Search insights</label>
      <input id="q" name="q" type="search" placeholder="Search articles…" value="<%= searchQuery || '' %>" autocomplete="off" />
      <button type="submit" class="btn btn--small">Search</button>
    </form>

    <% if (!posts || posts.length === 0) { %>
      <p class="muted">No articles match your search. Try different keywords or clear the search.</p>
      <% if (searchQuery) { %>
        <p><a href="/blog">View all insights</a></p>
      <% } %>
    <% } else { %>
      <div class="post-list">
        <% posts.forEach(function (p) { %>
          <article class="post-card card">
            <h2><a href="/blog/<%= p.slug %>"><%= p.title %></a></h2>
            <% if (p.excerpt) { %><p class="muted"><%= p.excerpt %></p><% } %>
            <a class="link-arrow" href="/blog/<%= p.slug %>">Read article</a>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>
