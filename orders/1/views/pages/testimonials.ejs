<section class="page-hero">
  <div class="container narrow">
    <p class="eyebrow">Social proof</p>
    <h1 class="display display--sm">Testimonials</h1>
    <p class="lead">Feedback from clients and partners who engaged 12 in luxury real estate across 12.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (!testimonials || testimonials.length === 0) { %>
      <p class="muted">Testimonials will appear here once they are added to the database.</p>
    <% } else { %>
      <div class="testimonial-grid">
        <% testimonials.forEach(function (t) { %>
          <article class="testimonial card">
            <div class="stars" aria-hidden="true"><%= '★'.repeat(Math.min(t.rating || 5, 5)) %></div>
            <blockquote class="testimonial-body"><%= t.body %></blockquote>
            <footer class="testimonial-meta">
              <strong><%= t.authorName %></strong>
              <% if (t.roleLocation) { %><span class="muted"> — <%= t.roleLocation %></span><% } %>
            </footer>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>
