# Server — preview dev often uses 3102 (do not use forbidden ports listed in README)
PORT=3102
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_2` only
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_2

# Legacy aliases (optional)
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

SESSION_SECRET=change-me-to-a-long-random-string

GA_MEASUREMENT_ID=

WHATSAPP_NUMBER=

CONTACT_WEBHOOK_URL=

SITE_URL=http://localhost:3102

# PM2 — autonix-order-2-dev (dev) or autonix-order-2-main (production)
# PM2_APP_NAME=autonix-order-2-dev
