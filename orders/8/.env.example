# Server — dev preview often uses 3114 (do not use forbidden ports listed in README)
PORT=3114
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_8` only
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_8

# Legacy aliases (optional)
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

GA_MEASUREMENT_ID=

WHATSAPP_NUMBER=

CONTACT_WEBHOOK_URL=

# Optional: show a mailto link on the contact page (public-facing inbox)
CONTACT_EMAIL=

# Public site URL (canonical, OG). Dev example: http://183.82.156.69:3114
SITE_URL=http://localhost:3114

# Client asset paths (defaults match Autonix upload layout for order #8)
# CLIENT_ASSETS_BASE=/uploads/website-client-assets/8
# CLIENT_LOGO_URL=/uploads/website-client-assets/8/1777098886598-qalvenn3-sood-mort-logo.png

# PM2 — autonix-order-8-dev (dev) or autonix-order-8-main (production)
# PM2_APP_NAME=autonix-order-8-dev
