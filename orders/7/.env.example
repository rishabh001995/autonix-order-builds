# Server — dev preview often uses 3112 (do not use forbidden ports listed in README)
PORT=3112
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_7` only
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_7

# Legacy aliases (optional)
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

GA_MEASUREMENT_ID=

WHATSAPP_NUMBER=

CONTACT_WEBHOOK_URL=

# Optional: show a mailto link on the contact page (public-facing inbox)
CONTACT_EMAIL=

# Public site URL (canonical, OG). Dev example: http://183.82.156.69:3112
SITE_URL=http://localhost:3112

# Client asset paths (defaults match Autonix upload layout for order #7)
# CLIENT_ASSETS_BASE=/uploads/website-client-assets/7
# CLIENT_LOGO_URL=
# CLIENT_HERO_URL=

# PM2 — autonix-order-7-dev (dev) or autonix-order-7-main (production)
# PM2_APP_NAME=autonix-order-7-dev
