<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Landzer' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>" />
  <link rel="canonical" href="<%= siteUrl %><%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>" />
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Landzer' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>" />
  <meta property="og:url" content="<%= siteUrl %><%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="<%= typeof ogImageUrl !== 'undefined' ? ogImageUrl : siteUrl %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>');
  </script>
  <% } %>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="grain" aria-hidden="true"></div>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">
        <% if (clientLogoUrl) { %>
        <img class="brand-logo" src="<%= clientLogoUrl %>" alt="Landzer — Real Estate" width="140" height="40" />
        <% } else { %>
        <span class="brand-wordmark">Landzer</span>
        <% } %>
        <span class="brand-tag">Real Estate</span>
      </a>
      <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="site-nav" data-nav-toggle>Menu</button>
      <nav id="site-nav" class="site-nav" data-nav>
        <a href="/">Home</a>
        <a href="/listings">Listings</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>
  <main id="main">
    <%- body %>
  </main>
  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <div class="footer-brand">Landzer</div>
        <p class="muted">Bold creative direction meets disciplined real estate practice — for people who want a home that fits how they actually live.</p>
      </div>
      <div>
        <h2 class="footer-heading">Explore</h2>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/listings">Featured listings</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h2 class="footer-heading">Connect</h2>
        <ul class="footer-links">
          <li><a href="/contact">Book a consultation</a></li>
          <% if (contactEmail) { %>
          <li><a href="mailto:<%= contactEmail %>">Email us</a></li>
          <% } %>
          <% if (whatsappNumber) { %>
          <li><a href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <% } %>
        </ul>
      </div>
    </div>
    <div class="container footer-bottom">
      <span>&copy; <%= new Date().getFullYear() %> Landzer · Real Estate · Custom Website Creation — John&apos;s Workspace</span>
    </div>
  </footer>
  <script src="/js/main.js" defer></script>
</body>
</html>
