<section class="hero hero--slate">
  <div class="hero-bg" aria-hidden="true">
    <% if (clientHeroUrl) { %>
    <img class="hero-photo" src="<%= clientHeroUrl %>" alt="" />
    <% } else { %>
    <img class="hero-photo" src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1600&q=85&auto=format&fit=crop" alt="" />
    <% } %>
    <div class="hero-scrim"></div>
  </div>
  <div class="container hero-grid">
    <div class="hero-copy reveal" data-reveal>
      <p class="eyebrow">Landzer · Real Estate</p>
      <h1 class="display">Homes that feel like a decision well made</h1>
      <p class="lead">
        We work with buyers and sellers who want more than a transaction — <strong>clarity on value</strong>, <strong>confidence in negotiation</strong>, and a path from first tour to keys without the usual chaos.
      </p>
      <div class="hero-actions">
        <a class="btn btn--primary" href="/listings">View featured listings</a>
        <a class="btn btn--ghost" href="/contact">Talk with our team</a>
      </div>
      <dl class="hero-stats">
        <div>
          <dt>Avg. days to offer</dt>
          <dd>12</dd>
        </div>
        <div>
          <dt>List-to-close focus</dt>
          <dd>End-to-end</dd>
        </div>
        <div>
          <dt>Markets</dt>
          <dd>Metro &amp; suburbs</dd>
        </div>
      </dl>
    </div>
    <aside class="hero-panel card reveal" data-reveal>
      <p class="panel-kicker">Why Landzer</p>
      <h2 class="h3">Real estate, without the noise</h2>
      <ul class="checklist">
        <li>Listing strategy shaped around real buyer behavior — not vanity metrics.</li>
        <li>Tour-ready prep, photography direction, and disclosure discipline from day one.</li>
        <li>Buyer representation with offer math you can explain to someone you trust.</li>
      </ul>
      <a class="text-link" href="/contact">Request a market snapshot →</a>
    </aside>
  </div>
</section>

<section class="section">
  <div class="container split">
    <div class="reveal" data-reveal>
      <h2 class="section-title">Built for how people actually buy homes</h2>
      <p class="muted">
        The <strong>Real Estate</strong> landscape rewards teams that combine creative presentation with operational rigor. Landzer brings both: memorable brand moments and the paperwork, timelines, and vendor coordination that keep deals on track.
      </p>
    </div>
    <div class="card card--accent reveal" data-reveal>
      <p class="pull-quote">“We optimize for calm — fewer surprises at inspection, cleaner communication with lenders, and a closing table that feels like a finish line, not a fight.”</p>
      <p class="muted small">— Landzer advisory team</p>
    </div>
  </div>
</section>

<section class="section section--dark">
  <div class="container">
    <div class="section-head reveal" data-reveal>
      <h2 class="section-title">How we partner with you</h2>
      <p class="muted narrow-inline">Three chapters — each with clear deliverables — so you always know what happens next.</p>
    </div>
    <div class="steps">
      <article class="step-card reveal" data-reveal>
        <span class="step-index">01</span>
        <h3>Discover</h3>
        <p class="muted">Goals, budget guardrails, neighborhoods, and non-negotiables — aligned before we open a single door.</p>
      </article>
      <article class="step-card reveal" data-reveal>
        <span class="step-index">02</span>
        <h3>Execute</h3>
        <p class="muted">Tours, comps, and offer strategy with transparent math — including scenarios for appraisal and repair asks.</p>
      </article>
      <article class="step-card reveal" data-reveal>
        <span class="step-index">03</span>
        <h3>Close</h3>
        <p class="muted">Coordination through escrow, final walkthrough, and handoff — with a checklist you can see in plain language.</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band reveal" data-reveal>
    <div>
      <h2 class="section-title">Ready when you are</h2>
      <p class="muted">Tell us whether you are buying, selling, or both — we will respond with next steps and timing.</p>
    </div>
    <a class="btn btn--primary" href="/contact">Start the conversation</a>
  </div>
</section>
