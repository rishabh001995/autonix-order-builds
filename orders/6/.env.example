# Server — dev preview often uses 3110 (do not use forbidden ports listed in README)
PORT=3110
NODE_ENV=development

# MySQL — dedicated schema `autonix_order_6` only
ORDER_DB_HOST=127.0.0.1
ORDER_DB_PORT=3306
ORDER_DB_USER=root
ORDER_DB_PASSWORD=
ORDER_DB_NAME=autonix_order_6

# Legacy aliases (optional)
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# Optional: true once if tables are missing and you are not applying sql/*.sql by hand
SYNC_DB=false

SESSION_SECRET=change-me-to-a-long-random-string

GA_MEASUREMENT_ID=

WHATSAPP_NUMBER=

CONTACT_WEBHOOK_URL=

# Optional: show a mailto link on the contact page (public-facing inbox)
CONTACT_EMAIL=

# Optional: POST JSON on successful checkout
ORDER_WEBHOOK_URL=

# Public site URL (canonical, OG). Dev example: http://183.82.156.69:3110
SITE_URL=http://localhost:3110

# Client asset paths (defaults match Autonix upload layout for order #6)
# CLIENT_ASSETS_BASE=/uploads/website-client-assets/6
# CLIENT_LOGO_URL=
# CLIENT_HERO_URL=

# PM2 — autonix-order-6-dev (dev) or autonix-order-6-main (production)
# PM2_APP_NAME=autonix-order-6-dev
